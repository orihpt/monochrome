{
    "manifest_version": 3,
    "name": "Monochrome Tidal Origin (offline-disabled)",
    "version": "1.0.0",
    "description": "Disabled by default for offline-first builds. Re-enable only when restoring TIDAL support.",
    "permissions": ["declarativeNetRequest", "scripting", "declarativeNetRequestWithHostAccess"],
    "host_permissions": ["*://localhost:*/*"],
    "offline_disabled_original_hosts": [
        "*://*.tidal.com/*",
        "*://monochrome.tf/*",
        "*://monochrome.samidy.com/*",
        "*://lossless.wtf/*"
    ],
    "declarative_net_request": {
        "rule_resources": [
            {
                "id": "rules",
                "enabled": false,
                "path": "rules.json"
            }
        ]
    },
    "content_scripts": [
        {
            "matches": ["*://localhost:*/*"],
            "js": ["content.js"],
            "run_at": "document_start",
            "all_frames": true
        }
    ],
    "icons": {
        "16": "icons/16.png",
        "48": "icons/48.png",
        "128": "icons/128.png"
    },
    "web_accessible_resources": [
        {
            "resources": ["inject.js"],
            "matches": ["*://localhost:*/*"]
        }
    ]
}
